# ─── Database ────────────────────────────────────────────────────────────
# Used by Prisma at runtime + migrations.
DATABASE_URL="postgresql://aaeasy:aaeasy@localhost:5432/aaeasy?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────
# Public origin (no trailing slash). Used for WebAuthn rpID/origin and cookies.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional human-readable name shown in passkey prompts.
NEXT_PUBLIC_APP_NAME="AAEasy"

# ─── Object storage (Vercel Blob) ────────────────────────────────────────
# Pull this from Vercel with `vercel env pull` after creating a Blob store.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Optional PDF font overrides. By default, Noto Sans SC is bundled for Vercel.
PDF_CJK_FONT_PATH=""
PDF_CJK_FONT_BOLD_PATH=""

# ─── Misc ────────────────────────────────────────────────────────────────
NODE_ENV="development"
ADMIN_SECRET="change-me"
# Optional initial username allowlist, separated by commas, spaces, semicolons, or newlines.
INITIAL_ALLOWED_USERNAMES="alice,bob"

AI_API_URL="https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway-name>/<provider>/v1/chat/completions"
AI_GATEWAY_TOKEN="xxx"
# Optional. Only needed when bypassing Gateway or when your Gateway provider forwards client Authorization.
AI_API_KEY=""
AI_MODEL="qwen3.6-plus"
AI_DEBUG_TIMING="false"
