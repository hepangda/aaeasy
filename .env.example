# ─── Database ────────────────────────────────────────────────────────────
# Used by Prisma at runtime + migrations.
DATABASE_URL="postgresql://aaeasy:aaeasy@localhost:5432/aaeasy?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────
# Public origin (no trailing slash). Used for WebAuthn rpID/origin and cookies.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional human-readable name shown in passkey prompts.
NEXT_PUBLIC_APP_NAME="AAEasy"

# ─── Object storage (MinIO / S3-compatible) ──────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="aaeasy-receipts"
S3_ACCESS_KEY="aaeasy"
S3_SECRET_KEY="aaeasy-secret"
S3_FORCE_PATH_STYLE="true"

# ─── Misc ────────────────────────────────────────────────────────────────
NODE_ENV="development"
ADMIN_SECRET="change-me"
# Optional initial username allowlist, separated by commas, spaces, semicolons, or newlines.
INITIAL_ALLOWED_USERNAMES="alice,bob"

AI_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"
AI_API_KEY=xxx
AI_MODEL="qwen3.6-plus"
AI_DEBUG_TIMING="false"
